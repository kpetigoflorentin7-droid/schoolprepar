{# templates/front/partials/nav.html.twig #}
<header class="header-area header-sticky">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <nav class="main-nav">
          <a href="{{ path('app_home') }}" class="logo">School<span>Prepar</span></a>
          <ul class="nav">
            <li class="scroll-to-section">
              <a href="{{ path('app_home') }}" class="{{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">Accueil</a>
            </li>
            <li>
              <a href="{{ path('app_filieres') }}" class="{{ app.request.attributes.get('_route') starts with 'app_filiere' ? 'active' : '' }}">Filières</a>
            </li>
            <li>
              <a href="{{ path('app_etablissements') }}" class="{{ app.request.attributes.get('_route') starts with 'app_etablissement' ? 'active' : '' }}">Établissements</a>
            </li>
            <li class="has-sub">
              <a href="javascript:void(0)">Pages</a>
              <ul class="sub-menu">
                <li><a href="{{ path('app_filieres') }}">Filières &amp; Établissements</a></li>
                <li><a href="{{ path('app_webinaires') }}">Webinaires</a></li>
                <li><a href="{{ path('app_webinaire_show', {id: 1}) }}">Détail Webinaire</a></li>
              </ul>
            </li>
            <li>
              <a href="{{ path('app_webinaires') }}" class="{{ app.request.attributes.get('_route') starts with 'app_webinaire' ? 'active' : '' }}">Webinaires</a>
            </li>
            <li class="scroll-to-section">
              <a href="{{ path('app_home') }}#contact">Contact</a>
            </li>
          </ul>

          {# ── Boutons Auth ─────────────────────────────────── #}
          <div style="display:flex; gap:10px; align-items:center; margin-left:20px;">
            {% if app.user %}
              <span style="color:white; font-size:13px; font-weight:600;">
                <i class="fa fa-user-circle" style="color:#f5a425; margin-right:5px;"></i>
                {{ app.user.prenom }} {{ app.user.nom }}
              </span>
              {% if is_granted('ROLE_ADMIN') %}
              <a href="{{ path('admin_dashboard') }}"
                 style="background:#f5a425; color:white; border:2px solid #f5a425; border-radius:25px; padding:7px 16px; font-size:12px; font-weight:700; text-decoration:none; white-space:nowrap;">
                <i class="fa fa-cog"></i> Admin
              </a>
              {% endif %}
              <a href="{{ path('app_logout') }}"
                 style="background:transparent; color:#ff4444; border:2px solid #ff4444; border-radius:25px; padding:7px 16px; font-size:12px; font-weight:700; text-decoration:none; white-space:nowrap;">
                <i class="fa fa-sign-out"></i> Déconnexion
              </a>
            {% else %}
              <a href="{{ path('app_login') }}"
                 style="background:transparent; color:white; border:2px solid white; border-radius:25px; padding:7px 18px; font-size:12px; font-weight:700; text-decoration:none; white-space:nowrap;">
                <i class="fa fa-sign-in"></i> Connexion
              </a>
              <a href="{{ path('app_register') }}"
                 style="background:#f5a425; color:white; border:2px solid #f5a425; border-radius:25px; padding:7px 18px; font-size:12px; font-weight:700; text-decoration:none; white-space:nowrap;">
                <i class="fa fa-user-plus"></i> Créer un compte
              </a>
            {% endif %}
          </div>

          <a class="menu-trigger"><span>Menu</span></a>
        </nav>
      </div>
    </div>
  </div>
</header>