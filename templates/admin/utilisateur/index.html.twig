{% extends 'admin/base.html.twig' %}
{% block title %}Utilisateurs{% endblock %}
{% block page_title %}Gestion des Utilisateurs{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Utilisateurs</li>{% endblock %}

{% block body %}
{% for type, msgs in app.flashes %}
  {% for m in msgs %}
    <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible">
      <button type="button" class="close" data-dismiss="alert">&times;</button>{{ m }}
    </div>
  {% endfor %}
{% endfor %}

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h3 class="card-title mb-0"><i class="fas fa-users mr-2"></i>Utilisateurs <small class="text-muted font-weight-normal">(9 par page · 3 par ligne)</small></h3>
  </div>
  <div class="card-body pb-2">
    <div class="row admin-user-grid">
      {% for u in utilisateurs %}
        <div class="col-12 col-sm-6 col-md-4 mb-3 admin-user-slide">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column user-card-body pt-4 pb-3 px-3">
              <div class="user-avatar-wrap">
                <i class="fas fa-user-circle"></i>
              </div>
              <div class="user-name">{{ u.prenom }} {{ u.nom }}</div>
              <div class="user-email">{{ u.email }}</div>
              <div>
                {% if 'ROLE_ADMIN' in u.roles %}
                  <span class="badge badge-danger">Admin</span>
                {% elseif 'ROLE_CONSEILLER' in u.roles %}
                  <span class="badge badge-info">Conseiller</span>
                {% else %}
                  <span class="badge badge-secondary">Élève</span>
                {% endif %}
              </div>
              <div class="user-card-actions">
                <a href="{{ path('admin_utilisateur_show', {id: u.id}) }}" class="btn btn-sm btn-info" title="Voir"><i class="fas fa-eye"></i></a>
                <form method="post" action="{{ path('admin_utilisateur_delete', {id: u.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete'~u.id) }}">
                  <button type="submit" class="btn btn-sm btn-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div class="col-12">
          <p class="text-center text-muted py-5 mb-0">Aucun utilisateur enregistré.</p>
        </div>
      {% endfor %}
    </div>
  </div>
  {% include 'admin/partials/pagination.html.twig' with { pagination_route: 'admin_utilisateurs', pagination: pagination } only %}
</div>
{% endblock %}
