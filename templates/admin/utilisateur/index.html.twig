{% extends 'admin/base.html.twig' %}
{% block title %}Utilisateurs{% endblock %}
{% block page_title %}Gestion des Utilisateurs{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Utilisateurs</li>{% endblock %}

{% block body %}
{% for type, msgs in app.flashes %}
  {% for m in msgs %}
    <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible">
      <button type="button" class="close" data-dismiss="alert">&times;</button>{{ m }}
    </div>
  {% endfor %}
{% endfor %}

<div class="card">
  <div class="card-header">
    <h3 class="card-title"><i class="fas fa-users mr-2"></i>Liste des utilisateurs</h3>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped table-hover mb-0">
      <thead class="thead-light">
        <tr>
          <th>#</th>
          <th>Nom complet</th>
          <th>Email</th>
          <th>Rôle</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
      {% for u in utilisateurs %}
        <tr>
          <td>{{ u.id }}</td>
          <td>{{ u.prenom }} {{ u.nom }}</td>
          <td>{{ u.email }}</td>
          <td>
            {% if 'ROLE_ADMIN' in u.roles %}
              <span class="badge badge-danger">Admin</span>
            {% elseif 'ROLE_CONSEILLER' in u.roles %}
              <span class="badge badge-info">Conseiller</span>
            {% else %}
              <span class="badge badge-secondary">Élève</span>
            {% endif %}
          </td>
          <td>
            <a href="{{ path('admin_utilisateur_show', {id: u.id}) }}" class="btn btn-xs btn-info"><i class="fas fa-eye"></i></a>
            <form method="post" action="{{ path('admin_utilisateur_delete', {id: u.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet utilisateur ?')">
              <input type="hidden" name="_token" value="{{ csrf_token('delete'~u.id) }}">
              <button class="btn btn-xs btn-danger"><i class="fas fa-trash"></i></button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="5" class="text-center text-muted py-4">Aucun utilisateur enregistré.{% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}