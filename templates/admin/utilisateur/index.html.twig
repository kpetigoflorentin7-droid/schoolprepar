{% extends 'admin/base.html.twig' %}

{% block title %}Utilisateurs – Admin SchoolPrepar{% endblock %}
{% block page_title %}Gestion des Utilisateurs{% endblock %}
{% block breadcrumb %}
  <li class="breadcrumb-item active">Utilisateurs</li>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('admin/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css') }}">
{% endblock %}

{% block body %}
  <div class="card">
    <div class="card-header sp-header d-flex justify-content-between align-items-center">
      <h3 class="card-title"><i class="fas fa-users mr-2"></i>Liste des utilisateurs</h3>
      <button class="btn btn-sm btn-warning" data-toggle="modal" data-target="#modalAjout">
        <i class="fas fa-plus mr-1"></i>Ajouter
      </button>
    </div>
    <div class="card-body">
      <table id="tableUtilisateurs" class="table table-bordered table-striped table-hover">
        <thead>
          <tr>
            <th>#</th>
            <th>Nom</th>
            <th>Email</th>
            <th>Rôle</th>
            <th>Statut</th>
            <th>Date d'inscription</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for user in utilisateurs %}
          <tr>
            <td>{{ user.id }}</td>
            <td><strong>{{ user.nom }}</strong></td>
            <td>{{ user.email }}</td>
            <td>
              <span class="badge badge-role badge-{{ user.role }}">{{ user.role|capitalize }}</span>
            </td>
            <td>
              <span class="status-dot {{ user.statut }}"></span>
              {% if user.statut == 'active' %}Actif
              {% elseif user.statut == 'pending' %}En attente
              {% else %}Inactif{% endif %}
            </td>
            <td>{{ user.date }}</td>
            <td>
              <button class="btn btn-xs btn-info" title="Voir"><i class="fas fa-eye"></i></button>
              <button class="btn btn-xs btn-warning" data-toggle="modal" data-target="#modalModifier" title="Modifier"><i class="fas fa-edit"></i></button>
              <button class="btn btn-xs btn-danger" onclick="return confirm('Supprimer cet utilisateur ?')" title="Supprimer"><i class="fas fa-trash"></i></button>
            </td>
          </tr>
          {% else %}
          <tr><td colspan="7" class="text-center text-muted">Aucun utilisateur enregistré.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  {# ── Modal Ajouter ────────────────────────────────────────── #}
  <div class="modal fade" id="modalAjout" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header sp-header">
          <h5 class="modal-title text-white"><i class="fas fa-user-plus mr-2"></i>Ajouter un utilisateur</h5>
          <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label>Nom complet</label>
            <input type="text" class="form-control" placeholder="Ex: Kofi Mensah">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control" placeholder="email@exemple.com">
          </div>
          <div class="form-group">
            <label>Rôle</label>
            <select class="form-control">
              <option value="eleve">Élève</option>
              <option value="conseiller">Conseiller</option>
              <option value="pro">Professionnel</option>
              <option value="admin">Administrateur</option>
            </select>
          </div>
          <div class="form-group">
            <label>Mot de passe</label>
            <input type="password" class="form-control" placeholder="••••••••">
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-dismiss="modal">Annuler</button>
          <button class="btn btn-warning"><i class="fas fa-save mr-1"></i>Enregistrer</button>
        </div>
      </div>
    </div>
  </div>

  {# ── Modal Modifier ───────────────────────────────────────── #}
  <div class="modal fade" id="modalModifier" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header sp-header">
          <h5 class="modal-title text-white"><i class="fas fa-user-edit mr-2"></i>Modifier l'utilisateur</h5>
          <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label>Nom complet</label>
            <input type="text" class="form-control" value="Kofi Mensah">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control" value="kofi@example.com">
          </div>
          <div class="form-group">
            <label>Rôle</label>
            <select class="form-control">
              <option value="eleve" selected>Élève</option>
              <option value="conseiller">Conseiller</option>
              <option value="pro">Professionnel</option>
              <option value="admin">Administrateur</option>
            </select>
          </div>
          <div class="form-group">
            <label>Statut</label>
            <select class="form-control">
              <option value="active" selected>Actif</option>
              <option value="pending">En attente</option>
              <option value="inactive">Inactif</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-dismiss="modal">Annuler</button>
          <button class="btn btn-warning"><i class="fas fa-save mr-1"></i>Mettre à jour</button>
        </div>
      </div>
    </div>
  </div>

{% endblock %}

{% block javascripts %}
<script src="{{ asset('admin/plugins/datatables/jquery.dataTables.min.js') }}"></script>
<script src="{{ asset('admin/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js') }}"></script>
<script>
  $(document).ready(function() {
    $('#tableUtilisateurs').DataTable({
      language: {
        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json'
      }
    });
  });
</script>
{% endblock %}
