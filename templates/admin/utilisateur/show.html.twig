{% extends 'admin/base.html.twig' %}
{% block title %}{{ utilisateur.prenom }} {{ utilisateur.nom }}{% endblock %}
{% block page_title %}{{ utilisateur.prenom }} {{ utilisateur.nom }}{% endblock %}
{% block breadcrumb %}
  <li class="breadcrumb-item"><a href="{{ path('admin_utilisateurs') }}">Utilisateurs</a></li>
  <li class="breadcrumb-item active">Profil</li>
{% endblock %}

{% block body %}
<div class="row">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header"><h3 class="card-title">Informations</h3></div>
      <div class="card-body">
        <table class="table table-bordered">
          <tr><th style="width:35%">Nom</th><td>{{ utilisateur.nom }}</td></tr>
          <tr><th>Prénom</th><td>{{ utilisateur.prenom }}</td></tr>
          <tr><th>Email</th><td>{{ utilisateur.email }}</td></tr>
          <tr><th>Téléphone</th><td>{{ utilisateur.telephone ?? '-' }}</td></tr>
          <tr>
            <th>Rôle</th>
            <td>
              {% if 'ROLE_ADMIN' in utilisateur.roles %}
                <span class="badge badge-danger">Admin</span>
              {% elseif 'ROLE_CONSEILLER' in utilisateur.roles %}
                <span class="badge badge-info">Conseiller</span>
              {% else %}
                <span class="badge badge-secondary">Élève</span>
              {% endif %}
            </td>
          </tr>
        </table>
      </div>
      <div class="card-footer">
        <a href="{{ path('admin_utilisateurs') }}" class="btn btn-default btn-sm">Retour</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}