<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Admin – SchoolPrepar{% endblock %}</title>

  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=fallback">

  {# AdminLTE CSS – fichiers à placer dans public/admin/ #}
  <link rel="stylesheet" href="{{ asset('admin/plugins/fontawesome-free/css/all.min.css') }}">
  <link rel="stylesheet" href="{{ asset('admin/dist/css/adminlte.min.css') }}">
  <link rel="stylesheet" href="{{ asset('admin/plugins/overlayScrollbars/css/OverlayScrollbars.min.css') }}">

  {# Thème SchoolPrepar #}
  <link rel="stylesheet" href="{{ asset('admin/assets/css/schoolprepar.css') }}">

  {% block stylesheets %}{% endblock %}
</head>
<body class="hold-transition sidebar-mini layout-fixed">
<div class="wrapper">

  {# ── Preloader ─────────────────────────────────────────────── #}
  <div class="preloader flex-column justify-content-center align-items-center">
    <i class="fas fa-graduation-cap fa-3x" style="color:#f5a623; animation: spin 1s linear infinite;"></i>
    <style>@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}</style>
  </div>

  {# ── Navbar top ────────────────────────────────────────────── #}
  {% include 'admin/partials/nav.html.twig' %}

  {# ── Sidebar ───────────────────────────────────────────────── #}
  {% include 'admin/partials/aside.html.twig' %}

  {# ── Contenu principal ─────────────────────────────────────── #}
  <div class="content-wrapper">
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0">{% block page_title %}Dashboard{% endblock %}</h1>
          </div>
          <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
              <li class="breadcrumb-item"><a href="{{ path('admin_dashboard') }}">Accueil</a></li>
              {% block breadcrumb %}{% endblock %}
            </ol>
          </div>
        </div>
      </div>
    </div>

    <section class="content">
      <div class="container-fluid">
        {% block body %}{% endblock %}
      </div>
    </section>
  </div>

  {# ── Footer ────────────────────────────────────────────────── #}
  {% include 'admin/partials/footer.html.twig' %}

</div>{# /.wrapper #}

{# AdminLTE JS #}
<script src="{{ asset('admin/plugins/jquery/jquery.min.js') }}"></script>
<script src="{{ asset('admin/plugins/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('admin/plugins/overlayScrollbars/js/jquery.overlayScrollbars.min.js') }}"></script>
<script src="{{ asset('admin/dist/js/adminlte.min.js') }}"></script>

{% block javascripts %}{% endblock %}
</body>
</html>
