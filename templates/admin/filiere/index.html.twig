{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Filières – Admin SchoolPrepar{% endblock %}
{% block page_title %}Filières{% endblock %}
{% block breadcrumb %}
  <li class="breadcrumb-item active">Filières</li>
{% endblock %}

{% block body %}
  <div class="card">
    <div class="card-header sp-header d-flex justify-content-between align-items-center">
      <h3 class="card-title"><i class="fas fa-book-open mr-2"></i>Liste des filières</h3>
      <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-plus mr-1"></i>Ajouter</a>
    </div>
    <div class="card-body p-0">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>#</th>
            <th>Nom</th>
            <th>Domaine</th>
            <th>Durée</th>
            <th>Niveau</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for filiere in filieres %}
          <tr>
            <td>{{ filiere.id }}</td>
            <td><strong>{{ filiere.nom }}</strong></td>
            <td><span class="badge-filiere">{{ filiere.domaine }}</span></td>
            <td>{{ filiere.duree }}</td>
            <td>{{ filiere.niveau }}</td>
            <td>
              <a href="{{ path('app_filiere_show', {id: filiere.id}) }}" class="btn btn-xs btn-info" target="_blank">
                <i class="fas fa-eye"></i>
              </a>
              <a href="#" class="btn btn-xs btn-warning"><i class="fas fa-edit"></i></a>
              <a href="#" class="btn btn-xs btn-danger" onclick="return confirm('Supprimer cette filière ?')">
                <i class="fas fa-trash"></i>
              </a>
            </td>
          </tr>
          {% else %}
          <tr><td colspan="6" class="text-center text-muted">Aucune filière enregistrée.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
