{% extends 'admin/base.html.twig' %}
{% block title %}Établissements{% endblock %}
{% block page_title %}Gestion des Établissements{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Établissements</li>{% endblock %}

{% block body %}
{% for type, msgs in app.flashes %}
  {% for m in msgs %}
    <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible">
      <button type="button" class="close" data-dismiss="alert">&times;</button>{{ m }}
    </div>
  {% endfor %}
{% endfor %}

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="card-title mb-0"><i class="fas fa-university mr-2"></i>Liste des établissements</h3>
    <a href="{{ path('admin_etablissement_new') }}" class="btn btn-primary btn-sm">
      <i class="fas fa-plus mr-1"></i>Nouvel établissement
    </a>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped table-hover mb-0">
      <thead class="thead-light">
        <tr>
          <th>#</th>
          <th>Nom</th>
          <th>Ville</th>
          <th>Email</th>
          <th>Tél.</th>
          <th>Filières</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
      {% for e in etablissements %}
        <tr>
          <td>{{ e.id }}</td>
          <td><strong>{{ e.nom }}</strong></td>
          <td>{{ e.ville ?? '-' }}</td>
          <td>{{ e.email ?? '-' }}</td>
          <td>{{ e.telephone ?? '-' }}</td>
          <td><span class="badge badge-success">{{ e.nb_filieres ?? 0 }}</span></td>
          <td>
            <a href="{{ path('admin_etablissement_show', {id: e.id}) }}" class="btn btn-xs btn-info"><i class="fas fa-eye"></i></a>
            <a href="{{ path('admin_etablissement_edit', {id: e.id}) }}" class="btn btn-xs btn-warning"><i class="fas fa-edit"></i></a>
            <form method="post" action="{{ path('admin_etablissement_delete', {id: e.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet établissement ?')">
              <input type="hidden" name="_token" value="{{ csrf_token('delete'~e.id) }}">
              <button class="btn btn-xs btn-danger"><i class="fas fa-trash"></i></button>
            </form>
          </td>
        </tr>
      {% else %}
        <td><td colspan="7" class="text-center text-muted py-4">Aucun établissement enregistré.{% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}