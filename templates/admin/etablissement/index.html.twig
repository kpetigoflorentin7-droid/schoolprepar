{% extends 'admin/base.html.twig' %}

{% block title %}Établissements – Admin SchoolPrepar{% endblock %}
{% block page_title %}Établissements{% endblock %}
{% block breadcrumb %}
  <li class="breadcrumb-item active">Établissements</li>
{% endblock %}

{% block body %}
  <div class="card">
    <div class="card-header sp-header d-flex justify-content-between align-items-center">
      <h3 class="card-title"><i class="fas fa-university mr-2"></i>Liste des établissements</h3>
      <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-plus mr-1"></i>Ajouter</a>
    </div>
    <div class="card-body p-0">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>#</th>
            <th>Nom</th>
            <th>Type</th>
            <th>Ville</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for etab in etablissements %}
          <tr>
            <td>{{ etab.id }}</td>
            <td><strong>{{ etab.nom }}</strong></td>
            <td>{{ etab.type }}</td>
            <td>{{ etab.ville }}</td>
            <td>
              <a href="#" class="btn btn-xs btn-warning"><i class="fas fa-edit"></i></a>
              <a href="#" class="btn btn-xs btn-danger" onclick="return confirm('Supprimer ?')">
                <i class="fas fa-trash"></i>
              </a>
            </td>
          </tr>
          {% else %}
          <tr><td colspan="5" class="text-center text-muted">Aucun établissement enregistré.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
