{% extends 'admin/base.html.twig' %}
{% block title %}Rendez-vous{% endblock %}
{% block page_title %}Gestion des Rendez-vous{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active">Rendez-vous</li>{% endblock %}

{% block body %}
{% for type, msgs in app.flashes %}
  {% for m in msgs %}
    <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible">
      <button type="button" class="close" data-dismiss="alert">&times;</button>{{ m }}
    </div>
  {% endfor %}
{% endfor %}

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="card-title mb-0"><i class="fas fa-calendar-check mr-2"></i>Liste des rendez-vous</h3>
    <a href="{{ path('admin_rdv_new') }}" class="btn btn-primary btn-sm">
      <i class="fas fa-plus mr-1"></i>Nouveau RDV
    </a>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped table-hover mb-0">
      <thead class="thead-light">
        <tr>
          <th>#</th>
          <th>Élève</th>
          <th>Conseiller</th>
          <th>Date & heure</th>
          <th>Mode</th>
          <th>Statut</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
      {% for rdv in rendezVous %}
        <tr>
          <td>{{ rdv.id }}</td>
          <td>{{ rdv.eleve_nom ?? 'Utilisateur supprimé' }}</td>
          <td>{{ rdv.conseiller_nom ?? 'Utilisateur supprimé' }}</td>
          <td>{{ rdv.date_heure|date('d/m/Y H:i') }}</td>
          <td>{{ rdv.mode ?? '-' }}</td>
          <td><span class="badge badge-{{ rdv.statut == 'confirme' ? 'success' : (rdv.statut == 'annule' ? 'danger' : 'warning') }}">{{ rdv.statut == 'confirme' ? 'Confirmé' : (rdv.statut == 'annule' ? 'Annulé' : 'En attente') }}</span></td>
          <td>
            <a href="{{ path('admin_rdv_show', {id: rdv.id}) }}" class="btn btn-xs btn-info"><i class="fas fa-eye"></i></a>
            <a href="{{ path('admin_rdv_edit', {id: rdv.id}) }}" class="btn btn-xs btn-warning"><i class="fas fa-edit"></i></a>
            <form method="post" action="{{ path('admin_rdv_delete', {id: rdv.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce rendez-vous ?')">
              <input type="hidden" name="_token" value="{{ csrf_token('delete'~rdv.id) }}">
              <button class="btn btn-xs btn-danger"><i class="fas fa-trash"></i></button>
            </form>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="7" class="text-center text-muted py-4">Aucun rendez-vous enregistré.</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
  {% include 'admin/partials/pagination.html.twig' with { pagination_route: 'admin_rdv', pagination: pagination } only %}
</div>
{% endblock %}