{% extends 'front/base.html.twig' %}

{% block title %}Connexion – SchoolPrepar{% endblock %}

{% block body %}

  <section class="heading-page header-text" id="top">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <h6>Bienvenue sur SchoolPrepar</h6>
          <h2>Connexion</h2>
        </div>
      </div>
    </div>
  </section>

  <section class="meetings-page" style="padding: 60px 0;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">

          {% if error %}
            <div class="alert alert-danger">
              <i class="fa fa-exclamation-triangle mr-2"></i>
              {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
          {% endif %}

          {% for msg in app.flashes('success') %}
            <div class="alert alert-success">
              <i class="fa fa-check-circle mr-2"></i>{{ msg }}
            </div>
          {% endfor %}

          <div class="card shadow-sm" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header text-white text-center py-3" style="background-color: #f5a425;">
              <h4 class="mb-0"><i class="fa fa-lock mr-2"></i>Se connecter</h4>
            </div>
            <div class="card-body p-4">

              <form method="post" action="{{ path('app_login') }}">

                <div class="mb-3">
                  <label class="form-label fw-bold">Adresse e-mail</label>
                  <input
                    type="email"
                    name="email"
                    class="form-control"
                    value="{{ last_username }}"
                    placeholder="exemple@mail.com"
                    required
                    autofocus
                  >
                </div>

                <div class="mb-3">
                  <label class="form-label fw-bold">Mot de passe</label>
                  <input
                    type="password"
                    name="password"
                    class="form-control"
                    placeholder="••••••••"
                    required
                  >
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="d-grid mt-4">
                  <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fa fa-sign-in mr-2"></i>Se connecter
                  </button>
                </div>
              </form>

            </div>
            <div class="card-footer text-center py-3 bg-light">
              <small>
                Pas encore de compte ?
                <a href="{{ path('app_register') }}" class="text-primary fw-bold">Créer un compte</a>
              </small>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

{% endblock %}